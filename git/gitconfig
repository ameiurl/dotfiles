[user]
	name = amei
	email = cms1984@msn.com
[core]
	quotepath = false
	autocrlf = false
[diff]
	tool = nvimdiff
[difftool "nvimdiff"]
	prompt = false
	trustExitCode = true
	cmd = "nvim -d -u ~/.vimrc \"$LOCAL\" \"$REMOTE\""
[alias]
	d = difftool
[color "diff"]
	meta = yellow bold
	commit = green bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse
[oh-my-zsh]
	hide-status = 1
	hide-dirty = 1
[credential]
	helper = store
[pull]
	rebase = false
[merge]
	tool = vimdiff
[mergetool]
	path = nvim
